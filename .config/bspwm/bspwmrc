#!/bin/bash
#  ╔═══════════════════════════════════════════════════════════════╗
#  ║  Quant BSPWM                                                 ║
#  ║  A precision-crafted tiling environment                      ║
#  ║  github.com/NuRichter/quant-bspwm                            ║
#  ╚═══════════════════════════════════════════════════════════════╝

QUANT_DIR="$HOME/.config/bspwm"
SCRIPTS_DIR="$HOME/scripts"

# ── Autostart ──────────────────────────────────────────────────────

run() {
    if ! pgrep -f "$1" > /dev/null 2>&1; then
        "$@" &
    fi
}

reload() {
    pkill -x "$1" 2>/dev/null
    sleep 0.1
    "$@" &
}

# Kill orphan processes from previous session
pkill -x sxhkd 2>/dev/null
pkill -x polybar 2>/dev/null
pkill -x dunst 2>/dev/null
pkill -x picom 2>/dev/null

sleep 0.2

# Core daemons
sxhkd -c "$HOME/.config/sxhkd/sxhkdrc" &
sleep 0.1

# Compositor
picom --config "$HOME/.config/picom/picom.conf" --daemon &

# Notification daemon
dunst -config "$HOME/.config/dunst/dunstrc" &

# Polybar
"$HOME/.config/polybar/launch.sh" &

# Wallpaper
if command -v feh &>/dev/null; then
    feh --bg-fill --no-fehbg "$HOME/wallpapers/quant-default.png" 2>/dev/null || \
    feh --bg-fill --no-fehbg "$(find "$HOME/wallpapers" -type f \( -name '*.png' -o -name '*.jpg' \) | shuf -n1)" 2>/dev/null
fi

# Cursor
xsetroot -cursor_name left_ptr &

# Input method for Japanese/Indonesian
if command -v fcitx5 &>/dev/null; then
    run fcitx5
elif command -v ibus-daemon &>/dev/null; then
    run ibus-daemon -drx
fi

# Polkit agent
run /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

# Clipboard manager
run clipmenud

# Auto-lock (10 min idle)
run xautolock -time 10 -locker "$SCRIPTS_DIR/quant-lock.sh"

# NetworkManager applet
run nm-applet

# Redshift (Surabaya coordinates)
run redshift -l -7.25:112.75 -t 6500:3800

# ── Monitor Configuration ─────────────────────────────────────────

INTERNAL_MONITOR=$(xrandr --query | grep " connected" | head -n1 | cut -d' ' -f1)
EXTERNAL_MONITOR=$(xrandr --query | grep " connected" | grep -v "$INTERNAL_MONITOR" | head -n1 | cut -d' ' -f1)

if [[ -n "$EXTERNAL_MONITOR" ]]; then
    xrandr --output "$INTERNAL_MONITOR" --primary --auto \
           --output "$EXTERNAL_MONITOR" --auto --right-of "$INTERNAL_MONITOR"
    bspc monitor "$INTERNAL_MONITOR" -d 一 二 三 四 五
    bspc monitor "$EXTERNAL_MONITOR" -d 六 七 八 九 十
else
    bspc monitor "$INTERNAL_MONITOR" -d 一 二 三 四 五 六 七 八 九 十
fi

# ── Global Settings ───────────────────────────────────────────────

# Window layout
bspc config border_width                2
bspc config window_gap                  10
bspc config top_padding                 38
bspc config bottom_padding              4
bspc config left_padding                4
bspc config right_padding               4
bspc config single_monocle              false
bspc config split_ratio                 0.52
bspc config borderless_monocle          true
bspc config gapless_monocle             true
bspc config paddingless_monocle         true

# Focus behavior
bspc config focus_follows_pointer       true
bspc config pointer_follows_focus       false
bspc config pointer_follows_monitor     true
bspc config pointer_modifier            mod4
bspc config pointer_action1             move
bspc config pointer_action2             resize_side
bspc config pointer_action3             resize_corner

# Colors (Quant palette)
bspc config normal_border_color         "#1e1c2a"
bspc config active_border_color         "#2a2837"
bspc config focused_border_color        "#f5c2e7"
bspc config presel_feedback_color       "#c4a7e7"

# Monocle
bspc config center_pseudo_tiled         true

# External rules
bspc config external_rules_command      "$QUANT_DIR/external-rules.sh"

# ── Window Rules ──────────────────────────────────────────────────

# Workspace assignments (kanji desktop names)
bspc rule -a firefox                    desktop='二' follow=on
bspc rule -a Chromium                   desktop='二' follow=on
bspc rule -a code-oss                   desktop='三' follow=on
bspc rule -a Code                       desktop='三' follow=on
bspc rule -a jetbrains-idea             desktop='三' follow=on
bspc rule -a Thunar                     desktop='四' follow=on
bspc rule -a pcmanfm                    desktop='四' follow=on
bspc rule -a Gimp-2.10                  desktop='五' follow=on
bspc rule -a Inkscape                   desktop='五' follow=on
bspc rule -a obs                        desktop='六' follow=on
bspc rule -a discord                    desktop='七' follow=on
bspc rule -a TelegramDesktop            desktop='七' follow=on
bspc rule -a Spotify                    desktop='八' follow=on
bspc rule -a steam                      desktop='九' follow=on

# Floating windows
bspc rule -a Lxappearance               state=floating center=on
bspc rule -a Pavucontrol                state=floating center=on
bspc rule -a Nm-connection-editor       state=floating center=on
bspc rule -a Galculator                 state=floating center=on
bspc rule -a feh                        state=floating center=on
bspc rule -a Sxiv                       state=floating center=on
bspc rule -a mpv                        state=floating center=on sticky=on
bspc rule -a Viewnior                   state=floating center=on
bspc rule -a File-roller                state=floating center=on
bspc rule -a Nitrogen                   state=floating center=on
bspc rule -a Arandr                     state=floating center=on
bspc rule -a Xarchiver                  state=floating center=on
bspc rule -a "VirtualBox Manager"       state=floating center=on
bspc rule -a Gpick                      state=floating center=on
bspc rule -a Screenkey                  state=floating manage=off
bspc rule -a xdg-desktop-portal-gtk     state=floating center=on
bspc rule -a "fcitx5-config-qt"         state=floating center=on

# Pseudo-tiled
bspc rule -a Zathura                    state=tiled

# Sticky
bspc rule -a Peek                       state=floating sticky=on

# Layer rules
bspc rule -a "Dunst"                    layer=above

echo "[Quant BSPWM] Session initialized at $(date '+%Y-%m-%d %H:%M:%S')"
